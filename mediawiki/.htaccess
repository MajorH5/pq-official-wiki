# Short URLs: /wiki/Page_title → index.php (see Manual:Short_URL)
# Hardening: 403 Forbidden for installer / internals (see Manual:Security, production checklist).
<IfModule mod_rewrite.c>
RewriteEngine On

# Main page at site root / (requires $wgMainPageIsDomainRoot in LocalSettings.php)
RewriteRule ^$ /index.php [L,QSA]

# Block web access to installer and other paths that should never be fetched directly.
# [F] = 403 Forbidden (not 404).
RewriteRule ^mw-config(/|$) - [F,L]
RewriteRule ^cache(/|$) - [F,L]
RewriteRule ^includes(/|$) - [F,L]
RewriteRule ^languages(/|$) - [F,L]
RewriteRule ^maintenance(/|$) - [F,L]
RewriteRule ^serialized(/|$) - [F,L]
RewriteRule ^tests(/|$) - [F,L]
RewriteRule ^vendor(/|$) - [F,L]
RewriteRule ^\.git(/|$) - [F,L]
RewriteRule ^LocalSettings\.php$ - [F,L]
RewriteRule ^AdminSettings\.php$ - [F,L]

# Pretty sitemap URL (core REST index); requires $wgSitemapApiConfig['enabled'] = true in LocalSettings.php
RewriteRule ^sitemap\.xml$ /rest.php/site/v1/sitemap/0 [L,QSA]

RewriteRule ^/?wiki(/.*)?$ %{DOCUMENT_ROOT}/index.php [L]
</IfModule>
