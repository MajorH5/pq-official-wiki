# Copy to .env and fill in. See MediaWiki installer / bot password setup.

WIKI_BOT_USER=
WIKI_BOT_NAME=
WIKI_BOT_PASSWORD=

MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_RANDOM_ROOT_PASSWORD=yes

# Roblox .ROBLOSECURITY value (no prefix) for assetdelivery downloads
ROBLOX_COOKIE=

# Shared secret for POST /ingest (Authorization: Bearer … or X-PQ-Wiki-Token)
DATADUMP_INGEST_SECRET=

# Quick test: limit to 3 items, 3 locations, 3 entities (1 / true / yes)
GENERATE_FEW_PAGES=

# Import logging: INFO (default), DEBUG, WARNING
PQ_IMPORT_LOG_LEVEL=INFO
# Pywikibot extra console output (1 / true / yes)
PQ_BOT_VERBOSE=
