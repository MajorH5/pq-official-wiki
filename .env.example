# Copy to .env and fill in. See MediaWiki installer / bot password setup.
#
# LocalSettings.php must load PixelQuestRoblox, e.g. add this line (snippet file is mounted by docker-compose):
#   require_once __DIR__ . '/LocalSettings.pixelquest-snippet.php';
# Or run: wfLoadExtension( 'PixelQuestRoblox' );

# Wiki username the bot uses to log in — must match last editor check (case-insensitive).
# If left empty, the bot defaults to Pqadmin. Wrong or empty value causes every page to be skipped as "human".
WIKI_BOT_USER=Pqadmin
WIKI_BOT_NAME=
WIKI_BOT_PASSWORD=

MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_RANDOM_ROOT_PASSWORD=yes

# Roblox .ROBLOSECURITY value (no prefix) for assetdelivery downloads
ROBLOX_COOKIE=

# Shared secret for POST /ingest (Authorization: Bearer … or X-PQ-Wiki-Token)
DATADUMP_INGEST_SECRET=

# Preferred name for server-to-server APIs (ingest + PixelQuestRoblox game API).
# If empty, PixelQuestRoblox falls back to DATADUMP_INGEST_SECRET so one value can cover both.
PQ_API_SECRET=

# Roblox Open Cloud — Messaging Service (publishMessage). Used when link codes are created / links change.
# Creator Dashboard → your API key: enable messaging-service + universe-messaging-service:publish for your experience.
ROBLOX_UNIVERSE_ID=
ROBLOX_OPEN_CLOUD_API_KEY=
# Topic name subscribed in-game (MessagingService:SubscribeAsync)
ROBLOX_MESSAGING_TOPIC=wiki-link

# Standard Data Store name (Open Cloud) whose entries are keyed by Roblox user id → player JSON
ROBLOX_DATA_STORE_NAME=

# Outbound email (MediaWiki password reset, notifications). Requires MediaWiki pear/mail (official image).
# Namecheap Private Email: default ssl://mail.privateemail.com:465 (Docker-friendly). If that fails, try:
#   PQ_SMTP_HOST=tls://mail.privateemail.com  PQ_SMTP_PORT=587
# Must match $wgPasswordSender / $wgEmergencyContact in LocalSettings.php (support@playpixelquest.com).
PQ_SMTP_PASSWORD=
# PQ_SMTP_HOST=ssl://mail.privateemail.com
# PQ_SMTP_PORT=465
# PQ_SMTP_USER=support@playpixelquest.com
# PQ_SMTP_IDHOST=playpixelquest.com

# Google reCAPTCHA v2 (checkbox): LinkRobloxAccount + account creation (ConfirmEdit) when both are set.
PQ_RECAPTCHA_SITE_KEY=
PQ_RECAPTCHA_SECRET_KEY=

# Debug: PixelQuestRoblox logs DataStore/Messaging and missing item sprite lookups to wfDebugLog group "pqroblox".
# In LocalSettings.php add: $wgDebugLogGroups['pqroblox'] = '/var/log/mediawiki/pqroblox.log';
# (create file writable by www-data, or use /tmp/pqroblox.log for local Docker)

# Absolute path inside the MediaWiki container to pq-datadump.json (items/skins/entities for lookups & icons).
# Example Docker bind: ./pq-datadump.json:/var/www/html/pq-datadump.json:ro
PQ_DATADUMP_PATH=/var/www/html/pq-datadump.json

# Folder with PQ_Item.wikitext etc. for `python -m pq_wiki import-templates` (Docker sets this automatically)
# WIKI_LAYOUT_TEMPLATES_DIR=

# Wiki import: rebuild all pages (ignore JSON diff). Use after changing templates/code without a new dump.
# PQ_IMPORT_FULL=1

# Google Analytics 4 (Extension:GTag). Requires GTag in the MediaWiki image (see mediawiki/Dockerfile); rebuild after pull.
# Example: G-XXXXXXXXXX from Google Analytics → Admin → Data streams.
# PQ_COOKIE_CONSENT_ENABLED=0 loads GA immediately without the consent bar (not recommended for EU/UK visitors).
PQ_GTAG_MEASUREMENT_ID=
PQ_COOKIE_CONSENT_ENABLED=1
PQ_GTAG_ANONYMIZE_IP=1
PQ_GTAG_HONOR_DNT=1
PQ_GTAG_TRACK_SENSITIVE=0
# Set to 1 only if you use a third-party CMP that implements IAB TCF (see Extension:GTag).
PQ_GTAG_ENABLE_TCF=0

# Quick test: cap import to N of each type (items, locations, entities). Example: 10
# Empty = full import. Legacy: true / yes = 3 each (old default).
GENERATE_FEW_PAGES=

# Import logging: INFO (default), DEBUG, WARNING
PQ_IMPORT_LOG_LEVEL=INFO
# Log every successful save with old/new revision id and byte sizes (noisy)
# PQ_IMPORT_VERBOSE_SAVE=1
# Pywikibot extra console output (1 / true / yes)
PQ_BOT_VERBOSE=
