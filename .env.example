# Copy to .env and fill in. See MediaWiki installer / bot password setup.

# Wiki username the bot uses to log in — must match last editor check (case-insensitive).
# If left empty, the bot defaults to Pqadmin. Wrong or empty value causes every page to be skipped as "human".
WIKI_BOT_USER=Pqadmin
WIKI_BOT_NAME=
WIKI_BOT_PASSWORD=

MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_RANDOM_ROOT_PASSWORD=yes

# Roblox .ROBLOSECURITY value (no prefix) for assetdelivery downloads
ROBLOX_COOKIE=

# Shared secret for POST /ingest (Authorization: Bearer … or X-PQ-Wiki-Token)
DATADUMP_INGEST_SECRET=

# Folder with PQ_Item.wikitext etc. for `python -m pq_wiki import-templates` (Docker sets this automatically)
# WIKI_LAYOUT_TEMPLATES_DIR=

# Quick test: cap import to N of each type (items, locations, entities). Example: 10
# Empty = full import. Legacy: true / yes = 3 each (old default).
GENERATE_FEW_PAGES=

# Import logging: INFO (default), DEBUG, WARNING
PQ_IMPORT_LOG_LEVEL=INFO
# Pywikibot extra console output (1 / true / yes)
PQ_BOT_VERBOSE=
